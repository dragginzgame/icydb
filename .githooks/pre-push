#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

# Keep hook cargo state repo-local so local hooks do not contend with sibling repos.
source "$ROOT/scripts/env/cargo-local.sh"

echo "Running pre-push checks (clippy all-targets)..."

# Keep architecture invariants in sync with local and CI checks.
make check-invariants

# Match CI: lint everything (tests/benches/examples) with warnings denied.
cargo clippy --workspace --all-targets -- -D warnings

echo "Pre-push checks passed."
