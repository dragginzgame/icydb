#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

is_zero_sha() {
    [[ "$1" =~ ^0+$ ]]
}

is_tag_deletion() {
    local local_ref="$1"
    local local_sha="$2"
    local remote_ref="$3"

    [[ "${remote_ref}" == refs/tags/* ]] || return 1
    if [[ "${local_ref}" == "(delete)" || "${local_ref}" == "delete" ]]; then
        return 0
    fi
    if [[ "${local_sha}" == "(delete)" || "${local_sha}" == "delete" ]]; then
        return 0
    fi
    is_zero_sha "${local_sha}"
}

ref_count=0
tag_delete_count=0
while read -r local_ref local_sha remote_ref remote_sha; do
    if [[ -z "${local_ref}${local_sha}${remote_ref}${remote_sha}" ]]; then
        continue
    fi
    ref_count=$((ref_count + 1))
    if is_tag_deletion "${local_ref}" "${local_sha}" "${remote_ref}"; then
        tag_delete_count=$((tag_delete_count + 1))
    fi
done

if [[ "${ref_count}" -gt 0 && "${ref_count}" -eq "${tag_delete_count}" ]]; then
    echo "Skipping pre-push checks for tag deletion-only push."
    exit 0
fi

# Derive repo-local cargo paths from the Makefile so hooks stay aligned with
# the repo-owned defaults after the old env shim removal.
export CARGO_HOME="${CARGO_HOME:-$(make --no-print-directory -s -C "$ROOT" print-cargo-home)}"
export CARGO_TARGET_DIR="${CARGO_TARGET_DIR:-$(make --no-print-directory -s -C "$ROOT" print-cargo-target-dir)}"

echo "Running pre-push checks (clippy all-targets)..."

# Keep architecture invariants in sync with local and CI checks.
make check-invariants

# Match CI: lint everything (tests/benches/examples) with warnings denied.
cargo clippy --workspace --all-targets -- -D warnings

echo "Pre-push checks passed."
