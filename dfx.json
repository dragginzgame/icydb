{
    "canisters": {
        "minimal": {
            "type": "custom",
            "candid": ".dfx/local/canisters/minimal/minimal.did",
            "build": "bash -c 'cargo run -p icydb-testing-integration --bin build_quickstart_canister -- minimal'",
            "wasm": ".dfx/local/canisters/minimal/minimal.wasm",
            "shrink": true,
            "gzip": true,
            "metadata": [
                {
                    "name": "candid:service"
                }
            ]
        },
        "quickstart": {
            "type": "custom",
            "candid": ".dfx/local/canisters/quickstart/quickstart.did",
            "build": "bash -c 'cargo run -p icydb-testing-integration --bin build_quickstart_canister -- quickstart'",
            "wasm": ".dfx/local/canisters/quickstart/quickstart.wasm",
            "shrink": true,
            "gzip": true,
            "metadata": [
                {
                    "name": "candid:service"
                }
            ]
        },
        "twenty": {
            "type": "custom",
            "candid": ".dfx/local/canisters/twenty/twenty.did",
            "build": "bash -c 'cargo run -p icydb-testing-integration --bin build_quickstart_canister -- twenty'",
            "wasm": ".dfx/local/canisters/twenty/twenty.wasm",
            "shrink": true,
            "gzip": true,
            "metadata": [
                {
                    "name": "candid:service"
                }
            ]
        }
    },
    "networks": {
        "staging": {
            "providers": [
                "https://icp0.io"
            ],
            "type": "persistent"
        },
        "mainnet": {
            "providers": [
                "https://icp0.io"
            ],
            "type": "persistent"
        }
    },
    "defaults": {
        "build": {
            "output": "canisters/"
        }
    },
    "metadata": [
        {
            "name": "candid:service"
        }
    ],
    "version": 1
}
