{
    "canisters": {
        "sql_test": {
            "type": "custom",
            "candid": ".dfx/local/canisters/sql_test/sql_test.did",
            "build": "bash -c 'cargo run -p icydb-testing-integration --bin build_sql_test_canister -- sql_test'",
            "wasm": ".dfx/local/canisters/sql_test/sql_test.wasm",
            "shrink": true,
            "gzip": true,
            "metadata": [
                {
                    "name": "candid:service"
                }
            ]
        }
    },
    "networks": {
        "staging": {
            "providers": [
                "https://icp0.io"
            ],
            "type": "persistent"
        },
        "mainnet": {
            "providers": [
                "https://icp0.io"
            ],
            "type": "persistent"
        }
    },
    "defaults": {
        "build": {
            "output": "canisters/"
        }
    },
    "metadata": [
        {
            "name": "candid:service"
        }
    ],
    "version": 1
}
